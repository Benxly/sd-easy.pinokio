{
  "run": [
    {
      "method": "shell.run",
      "params": {
        "path": "app",
        "message": "git pull"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "path": "app",
        "venv": "venv",
        "message": "pip install -r requirements.txt --upgrade"
      }
    },
    {
      "method": "notify",
      "params": {
        "html": "✅ SD Easy updated to latest version!",
        "type": "success"
      }
    }
  ]
}
